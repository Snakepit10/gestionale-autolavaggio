# Variabili d'ambiente del CRM (copiare in .env / variabili Railway).
# Qui sono elencate solo le variabili del modulo MQTT/impianto: le
# altre (DATABASE_URL, REDIS_URL, EMAIL_*, META_WHATSAPP_*, GOOGLE_*)
# sono documentate in config/settings.py e nei docs/.

# === MQTT (broker Mosquitto - impianto IoT) ===
# In produzione il CRM usa la rete privata Railway del servizio broker:
#   MQTT_HOST=mosquitto-broker.railway.internal
# In locale (broker su TCP Proxy Railway o Mosquitto locale):
#   MQTT_HOST=tramway.proxy.rlwy.net  MQTT_PORT=<porta proxy>
MQTT_HOST=
MQTT_PORT=1883
# Utente 'crm' del file passwd del broker (vedi mosquitto-broker/README.md)
MQTT_USER=crm
MQTT_PASSWORD=
